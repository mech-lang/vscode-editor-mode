{
  "scopeName": "source.mech",
  "patterns": [
    { "include": "#strings" },
    { "include": "#markdown" },
    { "include": "#comments" },
    { "include": "#blockHeaders" },
    { "include": "#tables" },
    { "include": "#arrays" },
    { "include": "#tuples" },
    { "include": "#sets" },
    { "include": "#assignment" },
    { "include": "#kindAnnotations" },
    { "include": "#fsm" },
    { "include": "#patternMatching" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#atoms" },
    { "include": "#identifiers" },
    { "include": "#terminators" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "begin": "--",
          "end": "$",
          "name": "comment.line.double-dash",
          "patterns": [
            {
              "match": "\\{[^}]+\\}",
              "name": "meta.comment.inline-eval"
            },
            {
              "include": "#inlineMarkdown"
            }
          ]
        }
      ]
    },

    "markdown": {
      "patterns": [
        {
          "begin": "^```\\s*mech\\b.*$",
          "end": "^```\\s*$",
          "name": "meta.embedded.block.mech",
          "patterns": [
            { "include": "#comments" },
            { "include": "#blockHeaders" },
            { "include": "#tables" },
            { "include": "#arrays" },
            { "include": "#tuples" },
            { "include": "#sets" },
            { "include": "#assignment" },
            { "include": "#kindAnnotations" },
            { "include": "#fsm" },
            { "include": "#patternMatching" },
            { "include": "#functions" },
            { "include": "#operators" },
            { "include": "#booleans" },
            { "include": "#numbers" },
            { "include": "#atoms" },
            { "include": "#identifiers" },
            { "include": "#terminators" }
          ]
        },
        {
          "begin": "^```\\s*$",
          "end": "^```\\s*$",
          "name": "markup.raw.block.fenced"
        },
        {
          "begin": "^```(?!\\s*mech\\b)\\s*\\S.*$",
          "end": "^```\\s*$",
          "name": "markup.raw.block.fenced"
        },
        {
          "match": "^\\s*\\$\\$.*$",
          "name": "markup.raw.block.latex"
        },
        {
          "match": "^(\\[\\^[^\\]]+\\])(\\s*:\\s*)",
          "captures": {
            "1": { "name": "constant.other.footnote.label" },
            "2": { "name": "punctuation.separator.key-value" }
          }
        },
        {
          "match": "^(\\[\\d+\\])(\\s*:\\s*)",
          "captures": {
            "1": { "name": "constant.other.reference.label" },
            "2": { "name": "punctuation.separator.key-value" }
          }
        },
        {
          "begin": "^(\\s*)(\\()(\\d+(?:\\.\\d+)*)(\\))(\\s+.*)?$",
          "beginCaptures": {
            "2": { "name": "punctuation.definition.section.begin" },
            "3": { "name": "entity.name.section" },
            "4": { "name": "punctuation.definition.section.end" },
            "5": { "name": "markup.heading" }
          },
          "end": "$",
          "name": "markup.heading.mech"
        },
        {
          "match": "^(\\s*)(\\d+)(\\.)(\\s+.*)\\n(\\s*-{2,}\\s*)$",
          "captures": {
            "2": { "name": "entity.name.section" },
            "3": { "name": "punctuation.definition.section" },
            "4": { "name": "markup.heading" },
            "5": { "name": "markup.heading.setext.2" }
          },
          "name": "markup.heading.numbered"
        },

        {
          "match": "^=+$",
          "name": "markup.heading.setext.1"
        },
        {
          "match": "^-{2,}\\s*$",
          "name": "markup.heading.setext.2"
        },
        {
          "begin": "^(\\s*)(\\d+)(\\.)(\\s+)",
          "beginCaptures": {
            "2": { "name": "constant.numeric" },
            "3": { "name": "punctuation.definition.list.begin" }
          },
          "end": "(?=^\\s*$|^\\s*(?:[-\\d]|\\([^)]*\\)|-\\[[ xX]\\]))",
          "name": "meta.list.ordered",
          "patterns": [
            { "include": "#inlineMarkdown" }
          ]
        },
        {
          "begin": "^(\\s*)(-\\[[ xX]\\]|-\\([^)]*\\)|-)\\s+",
          "beginCaptures": {
            "2": { "name": "punctuation.definition.list.begin" }
          },
          "end": "(?=^\\s*$|^\\s*(?:[-\\d]|\\([^)]*\\)|-\\[[ xX]\\]))",
          "name": "meta.list.item",
          "patterns": [
            { "include": "#inlineMarkdown" }
          ]
        },

        { "include": "#inlineMarkdown" }
      ]
    },

    "inlineMarkdown": {
      "patterns": [
        {
          "match": "`[^`]+`",
          "name": "markup.inline.raw"
        },
        {
          "match": "\\$\\$[^$]+\\$\\$",
          "name": "markup.inline.raw.latex"
        },
        {
          "match": "\\[\\^[^\\]]+\\]",
          "name": "constant.other.footnote.reference"
        },
        {
          "match": "\\[\\d+\\]",
          "name": "constant.other.reference"
        },
        {
          "match": "\\*\\*[^\\s*][^*\\n]*[^\\s*]\\*\\*",
          "name": "markup.bold"
        },
        {
          "match": "\\*[^\\s*][^*\\n]*[^\\s*]\\*",
          "name": "markup.italic"
        },
        {
          "match": "__[^_]+__",
          "name": "markup.underline"
        },
        {
          "match": "\\[([^\\]]+)\\]\\((https?:[^\\s)]+)\\)",
          "captures": {
            "0": { "name": "meta.link.inline.markdown" },
            "1": { "name": "string.other.link.title.markdown" },
            "2": { "name": "markup.underline.link.markdown" }
          }
        },
        {
          "match": "§\\d+",
          "name": "constant.other.reference"
        },
        {
          "match": "\\{\\{:[A-Za-z_][A-Za-z0-9_]*\\}\\}",
          "name": "constant.other.state-reference"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double"
        }
      ]
    },

    "arrays": {
      "patterns": [
        {
          "begin": "\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.array.begin" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.definition.array.end" }
          },
          "name": "meta.array",
          "patterns": [
            { "include": "#numbers" },
            { "include": "#atoms" },
            { "include": "#booleans" },
            { "include": "#strings" },
            { "include": "#kindAnnotations" },
            { "include": "#comprehensions" },
            { "include": "#functions" },
            { "include": "#identifiers" },
            { "include": "#operators" },
            { "include": "#arrays" },
            { "include": "#sets" }
          ]
        }
      ]
    },

    "tables": {
      "patterns": [
        {
          "begin": "^(?=\\s*\\|.*\\|\\s*$)(\\s*\\|)",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.table.row.begin" }
          },
          "end": "\\|\\s*$",
          "endCaptures": {
            "0": { "name": "punctuation.definition.table.row.end" }
          },
          "name": "meta.table.row",
          "patterns": [
            { "match": "\\|", "name": "punctuation.separator.table.column" },
            { "include": "#kindAnnotations" },
            { "include": "#numbers" },
            { "include": "#atoms" },
            { "include": "#booleans" },
            { "include": "#strings" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },

    "tuples": {
      "patterns": [
        {
          "begin": "\\((?=[^\\)]*,[^\\)]*\\))",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.tuple.begin" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.tuple.end" }
          },
          "name": "meta.tuple",
          "patterns": [
            { "include": "#numbers" },
            { "include": "#atoms" },
            { "include": "#booleans" },
            { "include": "#strings" },
            { "include": "#kindAnnotations" },
            { "include": "#comprehensions" },
            { "include": "#functions" },
            { "include": "#identifiers" },
            { "match": ",", "name": "punctuation.separator.tuple" },
            { "include": "#arrays" },
            { "include": "#sets" },
            { "include": "#tuples" }
          ]
        }
      ]
    },

    "blockHeaders": {
      "patterns": [
        {
          "match": "\\b[A-Za-z_][A-Za-z0-9_-]*:[A-Za-z_][A-Za-z0-9_-]*\\b",
          "name": "entity.name.section.block-header"
        },
        {
          "begin": "(\\b[A-Za-z_][A-Za-z0-9_-]*:[A-Za-z_][A-Za-z0-9_-]*\\b)(\\{)",
          "beginCaptures": {
            "1": { "name": "entity.name.section.block-header" },
            "2": { "name": "punctuation.definition.block.options.begin" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.definition.block.options.end" }
          },
          "name": "meta.block.header",
          "patterns": [
            {
              "match": "\\b[A-Za-z_][A-Za-z0-9_-]*\\b(?=\\s*:)",
              "name": "variable.other.option-key"
            },
            {
              "match": ":",
              "name": "punctuation.separator.key-value"
            },
            {
              "match": "\\b(true|false)\\b",
              "name": "constant.language.boolean"
            }
          ]
        }
      ]
    },

    "sets": {
      "patterns": [
        {
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.set.begin" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.set.end" }
          },
          "name": "meta.set",
          "patterns": [
            { "include": "#numbers" },
            { "include": "#atoms" },
            { "include": "#booleans" },
            { "include": "#strings" },
            { "include": "#kindAnnotations" },
            { "include": "#comprehensions" },
            { "include": "#functions" },
            { "include": "#identifiers" },
            { "include": "#operators" },
            { "include": "#arrays" },
            { "include": "#sets" }
          ]
        }
      ]
    },

    "assignment": {
      "patterns": [
        {
          "match": "^\\s*([\\p{L}_][\\p{L}\\p{N}_/\\-]*)(?=\\s*=\\s*[^=])",
          "captures": {
            "1": { "name": "variable.other.definition" }
          }
        },
        {
          "match": "(~)\\s*([A-Za-z_][A-Za-z0-9_/\\-]*)\\b(?=\\s*:=)",
          "captures": {
            "1": { "name": "keyword.operator.mutability" },
            "2": { "name": "variable.other.definition" }
          }
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_/\\-]*)\\b(?:\\s*<([^>]+)>)?(?=\\s*:=)",
          "captures": {
            "1": { "name": "variable.other.definition" },
            "2": { "name": "entity.name.type.kind" }
          }
        },
        {
          "match": "(<)([^>]+)(>)(?=\\s*:=)",
          "captures": {
            "1": { "name": "punctuation.definition.type.begin" },
            "2": { "name": "entity.name.type.kind" },
            "3": { "name": "punctuation.definition.type.end" }
          }
        },
        {
          "match": ":=",
          "name": "keyword.operator.assignment"
        },
        {
          "match": "(?<![<>=!])=(?![=>=])",
          "name": "keyword.operator.assignment"
        }
      ]
    },

    "kindAnnotations": {
      "patterns": [
        {
          "match": "(?:\\[[A-Za-z_][A-Za-z0-9_]*\\]|\\{[A-Za-z_][A-Za-z0-9_]*\\}):\\d+(?:,\\d+)*",
          "name": "entity.name.type.kind"
        },
        {
          "match": "(<)([^>]+)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.type.begin" },
            "2": { "name": "entity.name.type.kind" },
            "3": { "name": "punctuation.definition.type.end" }
          }
        }
      ]
    },

    "fsm": {
      "patterns": [
        {
          "match": "#[A-Za-z_][A-Za-z0-9_/-]*",
          "name": "entity.name.function"
        },
        {
          "match": "\\{\\{:[A-Za-z_][A-Za-z0-9_]*\\}\\}",
          "name": "constant.other.state-reference"
        },
        {
          "match": "->",
          "name": "punctuation.definition.transition.arrow"
        }
      ]
    },

    "comprehensions": {
      "patterns": [
        {
          "match": "<-",
          "name": "keyword.operator.comprehension.bind"
        },
        {
          "match": "\\.\\.",
          "name": "keyword.operator.range"
        },
        {
          "match": "⩵",
          "name": "keyword.operator.equality"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comprehension"
        }
      ]
    },

    "patternMatching": {
      "patterns": [
        {
          "begin": "^(\\s*[|├└]\\s+)(?=.*(?:=>|->))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.pattern-branch" }
          },
          "end": "$",
          "name": "meta.pattern.guard",
          "patterns": [
            { "match": "=>|->", "name": "punctuation.definition.mapping.arrow" },
            { "include": "#arrays" },
            { "include": "#tuples" },
            { "include": "#sets" },
            { "include": "#atoms" },
            { "include": "#numbers" },
            { "include": "#booleans" },
            { "include": "#strings" },
            { "include": "#kindAnnotations" },
            { "include": "#fsm" },
            { "include": "#comprehensions" },
            { "include": "#functions" },
            { "include": "#identifiers" },
            { "match": "\\*", "name": "constant.language.wildcard" },
            { "include": "#operators" }
          ]
        },
        {
          "match": "^\\s*([|├└])\\s+",
          "captures": {
            "1": { "name": "punctuation.definition.pattern-branch" }
          }
        },
        {
          "match": "\\?(?=\\s|$)",
          "name": "keyword.operator.pattern-match"
        },
        {
          "match": "=>",
          "name": "punctuation.definition.mapping.arrow"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "match": "\\b[A-Za-z_][A-Za-z0-9_/\\-]*(?=\\()",
          "name": "entity.name.function"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "match": "[⋈⟕⟖⟗⋉▷]",
          "name": "keyword.operator.relational.join"
        },
        {
          "match": "[∪∩∖⊆⊇∈∉]",
          "name": "keyword.operator.set"
        },
        {
          "match": "'",
          "name": "keyword.operator.transpose"
        },
        {
          "match": "[:+\\-*/=|^]",
          "name": "keyword.operator"
        }
      ]
    },

    "booleans": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.typed",
          "match": "\\b-?\\d+(?:[uif]\\d+)\\b"
        },
        {
          "name": "constant.numeric.float",
          "match": "\\b-?\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.rational",
          "match": "\\b-?\\d+/\\d+\\b"
        },
        {
          "name": "constant.numeric.integer",
          "match": "\\b(0x[0-9A-Fa-f]+|0o[0-7]+|0b[01]+|0d\\d+|\\d+)\\b"
        }
      ]
    },

    "atoms": {
      "patterns": [
        {
          "match": ":[A-Za-z_][A-Za-z0-9_/-]*",
          "name": "constant.language"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "match": "\\b[\\p{L}_][\\p{L}\\p{N}_/\\-]*\\b(?=\\.[\\p{L}_])",
          "name": "variable.other.readwrite"
        },
        {
          "match": "\\.[\\p{L}_][\\p{L}\\p{N}_/\\-']*",
          "name": "entity.other.attribute-name.member-access"
        },
        {
          "match": "\\b[\\p{L}_][\\p{L}\\p{N}_/\\-]*\\b(?=')",
          "name": "variable.other.readwrite"
        },
        {
          "match": "\\b[\\p{L}_][\\p{L}\\p{N}_/\\-]*\\b(?=\\s*(?:\\*\\*|[+\\-*/=]))",
          "name": "variable.other.readwrite"
        },
        {
          "match": "~[A-Za-z_][A-Za-z0-9_/\\-]*",
          "name": "variable.other.readwrite.mutable"
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_/\\-]*)\\b(\\s*[⋈⟕⟖⟗⋉▷∪∩∖⊆⊇∈∉]\\s*)([A-Za-z_][A-Za-z0-9_/\\-]*)\\b",
          "captures": {
            "1": { "name": "variable.other.readwrite" },
            "2": { "name": "keyword.operator" },
            "3": { "name": "variable.other.readwrite" }
          }
        },
        {
          "match": "\\b[A-Za-z_][A-Za-z0-9_/\\-]*\\b(?=\\s*(?!\\[\\^)[\\[\\]()=|<>?:⋈⟕⟖⟗⋉▷∪∩∖⊆⊇∈∉])",
          "name": "variable.other.readwrite"
        },
        {
          "match": "\\b[\\p{L}_][\\p{L}\\p{N}_/\\-]*\\b(?=\\s*(?!\\[\\^)[\\[\\]()=|<>?:⋈⟕⟖⟗⋉▷∪∩∖⊆⊇∈∉])",
          "name": "variable.other.readwrite"
        }
      ]
    },

    "terminators": {
      "patterns": [
        {
          "match": "\\.(?=\\s*$)",
          "name": "punctuation.terminator.statement"
        }
      ]
    }

  }
}
